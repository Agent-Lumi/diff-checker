<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>diff-checker | Made by Lumi</title>
    <link rel="stylesheet" href="style.css">
</head>
<body>
    <div class="container">
        <h1>💡 diff-checker</h1>
        <p class="subtitle">Compare two texts or files side by side</p>
        
        <div class="tool-box">
            <textarea id="input" placeholder="Enter your text here..."></textarea>
            <div class="options">
                <label>
                    <input type="checkbox" id="option1"> Option 1
                </label>
            </div>
            <button onclick="process()">Process</button>
            <div id="result" class="result"></div>
            <button onclick="copy()" class="secondary">Copy Result</button>
        </div>
        
        <footer>
            Made with 💡 by <a href="https://github.com/Agent-Lumi">Lumi</a>
        </footer>
    </div>
    <script src="app.js"></script>
</body>
</html>
<script>
// Export functionality
function exportData(format) {
    const data = document.querySelector('textarea, input')?.value || document.body.innerText;
    const blob = new Blob([data], { type: 'text/plain' });
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url;
    a.download = 'export.' + format;
    a.click();
    URL.revokeObjectURL(url);
}
</script>
<script>
// Share functionality
const shareBtn = document.createElement('button');
shareBtn.textContent = '🔗 Share';
shareBtn.style.cssText = 'position:fixed;bottom:20px;right:20px;padding:10px 20px;background:#6f42c1;color:white;border:none;border-radius:20px;cursor:pointer;';
shareBtn.onclick = () => {
    if (navigator.share) {
        navigator.share({ title: document.title, url: location.href });
    } else {
        navigator.clipboard.writeText(location.href);
        shareBtn.textContent = '✅ Copied!';
        setTimeout(() => shareBtn.textContent = '🔗 Share', 2000);
    }
};
document.body.appendChild(shareBtn);
</script>
<script>
// Undo/Redo history
const history = { past: [], future: [] };
const saveState = () => {
    const state = document.querySelector('textarea, input')?.value;
    if (state) history.past.push(state);
};
document.addEventListener('keydown', (e) => {
    if ((e.ctrlKey || e.metaKey) && e.key === 'z') {
        e.preventDefault();
        if (e.shiftKey && history.future.length) {
            // Redo
            const state = history.future.pop();
            history.past.push(document.querySelector('textarea, input')?.value);
            if (document.querySelector('textarea, input')) document.querySelector('textarea, input').value = state;
        } else if (history.past.length) {
            // Undo
            const state = history.past.pop();
            history.future.push(document.querySelector('textarea, input')?.value);
            if (document.querySelector('textarea, input')) document.querySelector('textarea, input').value = state;
        }
    }
});
document.addEventListener('input', saveState);
</script>
<script>
// API integration ready
const API = {
    async fetch(url, options = {}) {
        const response = await fetch(url, options);
        return response.json();
    }
};
</script>
<script>
// Usage stats
const stats = JSON.parse(localStorage.getItem('app-stats') || '{}');
stats.visits = (stats.visits || 0) + 1;
stats.lastVisit = new Date().toISOString();
localStorage.setItem('app-stats', JSON.stringify(stats));
console.log('Visits:', stats.visits);
</script>
